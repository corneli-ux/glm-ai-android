<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base theme — used by AndroidManifest, then overridden by Compose Surface in MainActivity -->
    <style name="Theme.GLMAIApp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme (Android 12+) -->
    <style name="Theme.GLMAIApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/surface_light</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.GLMAIApp</item>
    </style>
</resources>
